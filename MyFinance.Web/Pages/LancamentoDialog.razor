@using MyFinance.Web.DTOs
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="Descricao" Label="Descrição" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="6">
                @* Valor sempre positivo visualmente *@
                <MudNumericField @bind-Value="Valor" Label="Valor" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentText="R$" Format="N2" Min="0.01M" />
            </MudItem>

            <MudItem xs="6">
                @* Tipo desbloqueado para permitir corrigir sinal (Receita vs Despesa) *@
                <MudSelect T="string" Label="Tipo" @bind-Value="TipoSelecionado"
                           AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Disabled="true">
                    <MudSelectItem Value="@("Receita")" />
                    <MudSelectItem Value="@("Despesa")" />
                </MudSelect>
            </MudItem>

            <MudItem xs="6">
                @* --- VERSÃO PC: Calendário elegante do MudBlazor --- *@
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudDatePicker Label="Data" @bind-Date="DataVencimento" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudHidden>

                @* --- VERSÃO MOBILE: Seletor Nativo do Android/iOS --- *@
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudTextField T="DateTime?"
                                  Label="Data"
                                  @bind-Value="DataVencimento"
                                  InputType="InputType.Date"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Format="yyyy-MM-dd" />
                </MudHidden>
            </MudItem>

            <MudItem xs="6">
                @* Disabled se estiver editando *@
                <MudSelect T="CategoriaDto"
                           Label="Categoria"
                           Value="_categoriaSelecionada"
                           ValueChanged="OnCategoriaChanged"
                           ToStringFunc="@(cat => cat?.Nome)"
                           AnchorOrigin="Origin.BottomCenter"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Disabled="@(LancamentoEditar != null)">
                    @if (categorias != null)
                    {
                        @foreach (var cat in categorias)
                        {
                            <MudSelectItem Value="@cat">@cat.Nome</MudSelectItem>
                        }
                    }
                </MudSelect>
                @if (LancamentoEditar != null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning">Categoria fixa na edição.</MudText>
                }
            </MudItem>

            @* --- [ADICIONADO] BLOCO DE RECORRÊNCIA --- *@
            <MudItem xs="12">
                <MudSwitch @bind-Value="EhRecorrente" Label="Repetir lançamento" Color="Color.Primary" />
            </MudItem>

            @if (EhRecorrente)
            {
                <MudItem xs="6">
                    <MudSelect T="int" Label="Frequência" @bind-Value="Frequencia" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="1">Semanal</MudSelectItem>
                        <MudSelectItem Value="2">Mensal</MudSelectItem>
                        <MudSelectItem Value="3">Anual</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="TotalParcelas" Label="Parcelas" Variant="Variant.Outlined" Margin="Margin.Dense" Min="2" Max="120" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_processando">
            @if (_processando)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Processando...</MudText>
            }
            else
            {
                <MudText>@(LancamentoEditar == null ? "Salvar" : "Atualizar")</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public Guid ContaId { get; set; }
    [Parameter] public LancamentoDto? LancamentoEditar { get; set; }

    public string Descricao { get; set; } = string.Empty;
    public decimal Valor { get; set; } = 0;
    public string TipoSelecionado { get; set; } = "Despesa";
    public DateTime? DataVencimento { get; set; } = DateTime.Today;

    // --- NOVOS CAMPOS ---
    public bool EhRecorrente { get; set; }
    public int Frequencia { get; set; } = 2;
    public int TotalParcelas { get; set; } = 2;

    private CategoriaDto? _categoriaSelecionada;
    private List<CategoriaDto>? categorias;
    private bool _processando = false;

    private string DataMobile
    {
        get => DataVencimento?.ToString("yyyy-MM-dd") ?? "";
        set => DataVencimento = DateTime.TryParse(value, out var dt) ? dt : null;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categorias = await Http.GetFromJsonAsync<List<CategoriaDto>>("api/categorias");
            categorias = categorias?.Where(c => c.Ativo).OrderBy(c => c.Nome).ToList();

            if (LancamentoEditar != null)
            {
                Descricao = LancamentoEditar.Descricao;
                DataVencimento = LancamentoEditar.Data;

                // Mapeamento dos novos campos na edição
                EhRecorrente = LancamentoEditar.EhRecorrente;
                Frequencia = LancamentoEditar.Frequencia > 0 ? LancamentoEditar.Frequencia : 2;
                TotalParcelas = LancamentoEditar.TotalParcelas > 0 ? LancamentoEditar.TotalParcelas : 2;

                if (LancamentoEditar.Valor < 0)
                {
                    TipoSelecionado = "Despesa";
                    Valor = Math.Abs(LancamentoEditar.Valor);
                }
                else
                {
                    TipoSelecionado = "Receita";
                    Valor = LancamentoEditar.Valor;
                }

                if (categorias != null)
                {
                    _categoriaSelecionada = categorias.FirstOrDefault(c => c.Id == LancamentoEditar.CategoriaId);
                }
            }
            else
            {
                if (categorias != null && categorias.Any())
                {
                    OnCategoriaChanged(categorias.First());
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar dados.", Severity.Warning);
        }
    }

    private void OnCategoriaChanged(CategoriaDto categoria)
    {
        _categoriaSelecionada = categoria;
        if (categoria != null && LancamentoEditar == null)
        {
            TipoSelecionado = categoria.Tipo;
        }
    }

    void Cancel() => MudDialog.Cancel();

    async Task Submit()
    {
        if (Valor <= 0)
        {
            Snackbar.Add("O valor deve ser maior que zero.", Severity.Warning);
            return;
        }

        if (LancamentoEditar == null && _categoriaSelecionada == null)
        {
            Snackbar.Add("Selecione uma categoria.", Severity.Warning);
            return;
        }

        _processando = true;

        try
        {
            decimal valorFinal = TipoSelecionado == "Despesa" ? Math.Abs(Valor) * -1 : Math.Abs(Valor);

            // Command unificado enviando os dados de recorrência
            var command = new
            {
                Id = LancamentoEditar?.Id ?? Guid.Empty,
                Descricao = Descricao,
                Valor = valorFinal,
                DataVencimento = DataVencimento ?? DateTime.Now,
                ContaId = ContaId,
                CategoriaId = _categoriaSelecionada?.Id ?? Guid.Empty,
                EhRecorrente = EhRecorrente,
                Frequencia = Frequencia,
                TotalParcelas = TotalParcelas
            };

            HttpResponseMessage response;

            if (LancamentoEditar == null)
            {
                response = await Http.PostAsJsonAsync("api/lancamentos", command);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/lancamentos/{LancamentoEditar.Id}", command);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(LancamentoEditar == null ? "Lançamento criado!" : "Atualizado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Erro ao salvar operação.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processando = false;
        }
    }
}