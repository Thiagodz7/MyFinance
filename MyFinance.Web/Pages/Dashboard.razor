@page "/"
@using MyFinance.Web.DTOs
@using MyFinance.Web.Services
@using MyFinance.Web.Shared
@using System.Globalization
@inject HttpClient Http
@inject PageStateService PageState
@implements IDisposable
@inject FinanceStateService FinanceState
@inject MyFinanceLocalDb LocalDb

<style>
    /* Estilos Premium para a Tabela de Previsão */
    .previsao-row {
        transition: all 0.2s ease-in-out;
        cursor: default;
    }

        .previsao-row:hover {
            background-color: #F8FAFC !important;
            transform: translateX(4px); /* Animação lateral suave */
        }

    .previsao-card {
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        overflow: hidden;
        background-color: white;
    }

    .header-table {
        background-color: #F1F5F9;
        border-bottom: 2px solid #E2E8F0;
    }
</style>

<PageTitle>Dashboard - Pejota.io</PageTitle>

<PageHeader Title="Dashboard" Subtitle="Visão geral de suas finanças este mês" />

@if (_carregando)
{
    <div class="d-flex flex-column align-center justify-center mt-15">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Class="mt-4" Style="color: #64748B;">Sincronizando seus dados...</MudText>
    </div>
}
else if (dashboard == null)
{
    <MudEmptyState Title="Sem dados para exibir"
                   Message="Parece que esta conta ainda não possui movimentações este mês."
                   Icon="@Icons.Material.Filled.Insights"
                   IconColor="Color.Info" />
}
else
{
    <MudGrid Class="mb-6">
        @* Widget de Receitas *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 border border-solid mud-border-lines-default" Style="border-radius: 16px; border-left: 6px solid #10B981 !important;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Success" Class="mr-3" />
                    <MudText Typo="Typo.subtitle2" Style="color: #64748B; font-weight: 600;">RECEITAS</MudText>
                </div>
                <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight: 800; color: #10B981;">@dashboard.TotalReceitas.ToString("C2")</MudText>
            </MudPaper>
        </MudItem>

        @* Widget de Despesas *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 border border-solid mud-border-lines-default" Style="border-radius: 16px; border-left: 6px solid #EF4444 !important;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Color="Color.Error" Class="mr-3" />
                    <MudText Typo="Typo.subtitle2" Style="color: #64748B; font-weight: 600;">DESPESAS</MudText>
                </div>
                <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight: 800; color: #EF4444;">@dashboard.TotalDespesas.ToString("C2")</MudText>
            </MudPaper>
        </MudItem>

        @* Widget de Lucro *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Class="pa-4 border border-solid mud-border-lines-default" Style="border-radius: 16px; border-left: 6px solid #3B82F6 !important;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Info" Class="mr-3" />
                    <MudText Typo="Typo.subtitle2" Style="color: #64748B; font-weight: 600;">LUCRO LÍQUIDO</MudText>
                </div>
                <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight: 800; color: #1E293B;">@dashboard.SaldoTotal.ToString("C2")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="7">
            <MudPaper Elevation="0" Class="pa-6 border border-solid mud-border-lines-default" Style="border-radius: 16px; height: 100%;">
                <div class="d-flex align-center mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.PieChart" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">Distribuição de Gastos</MudText>
                </div>

                @if (dataGrafico != null && dataGrafico.Length > 0)
                {
                    <div class="d-flex flex-column align-center">
                        <div class="d-flex justify-center align-center" style="width: 100%; min-height: 250px;">
                            <MudChart ChartType="ChartType.Donut" Width="220px" Height="220px" InputData="@dataGrafico" InputLabels="@labelsGrafico" ChartOptions="@_chartOptions" />
                        </div>
                        <div class="d-flex flex-wrap justify-center gap-4 mt-6">
                            @for (int i = 0; i < labelsGrafico.Length; i++)
                            {
                                var localIndex = i;
                                <div class="d-flex align-center">
                                    <div style="@($"width:12px; height:12px; border-radius:50%; background-color:{_chartOptions.ChartPalette[localIndex % _chartOptions.ChartPalette.Length]}; margin-right:8px;")"></div>
                                    <MudText Typo="Typo.caption" Style="color: #1E293B; font-weight: 500;">@labelsGrafico[localIndex]: <b>@dataGrafico[localIndex].ToString("C2")</b></MudText>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex align-center justify-center" style="height: 300px;">
                        <MudText Style="color: #94A3B8;">Nenhuma despesa para exibir o gráfico.</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="0" Class="pa-6 border border-solid mud-border-lines-default" Style="border-radius: 16px; background-color: #F8FAFC; height: 100%;">
                <MudText Typo="Typo.h6" Style="font-weight: 700;" Class="mb-4">Insights Financeiros</MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" DropShadow="false" Class="mb-4 rounded-lg">Seu lucro aumentou 12% em relação ao mês passado! 🚀</MudAlert>
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-center justify-space-between">
                        <MudText Typo="Typo.body2" Style="color: #64748B;">Análise Tributária PJ</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">EM BREVE</MudChip>
                    </div>
                    <MudDivider />
                    <div class="d-flex align-center justify-space-between">
                        <MudText Typo="Typo.body2" Style="color: #64748B;">Previsão de Impostos</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">LABS</MudChip>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="0" Class="pa-6 border border-solid mud-border-lines-default" Style="border-radius: 16px;">
                <div class="d-flex align-center justify-space-between mb-6">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Previsibilidade de Caixa</MudText>
                    </div>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Icon="@Icons.Material.Filled.CalendarMonth">PRÓXIMOS 6 MESES</MudChip>
                </div>

                @if (seriesPrevisao.Any(s => s.Data.Any(v => v != 0)))
                {
                    <MudGrid>
                        <MudItem xs="12" lg="7">
                            <MudChart ChartType="ChartType.Line" ChartSeries="@seriesPrevisao" XAxisLabels="@labelsPrevisao" Width="100%" Height="320px" ChartOptions="@_lineOptions" />
                        </MudItem>

                        <MudItem xs="12" lg="5">
                            <div class="previsao-card">
                                <table class="w-100" style="border-collapse: collapse;">
                                    <thead class="header-table">
                                        <tr>
                                            <th class="pa-3 text-start"><MudText Typo="Typo.caption" Style="font-weight: 800;">MÊS</MudText></th>
                                            <th class="pa-3 text-end"><MudText Typo="Typo.caption" Style="font-weight: 800; color: #10B981;">ENTRADAS</MudText></th>
                                            <th class="pa-3 text-end"><MudText Typo="Typo.caption" Style="font-weight: 800; color: #EF4444;">SAÍDAS</MudText></th>
                                            <th class="pa-3 text-end"><MudText Typo="Typo.caption" Style="font-weight: 800; color: #3B82F6;">SALDO</MudText></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in dashboard.PrevisaoProximosMeses)
                                        {
                                            <tr class="previsao-row" style="border-bottom: 1px solid #F1F5F9;">
                                                <td class="pa-3"><MudText Typo="Typo.body2" Style="font-weight: 700; color: #475569;">@item.Mes</MudText></td>
                                                <td class="pa-3 text-end"><MudText Typo="Typo.body2" Color="Color.Success">@item.Receitas.ToString("C2")</MudText></td>
                                                <td class="pa-3 text-end"><MudText Typo="Typo.body2" Color="Color.Error">@item.Despesas.ToString("C2")</MudText></td>
                                                <td class="pa-3 text-end" style="background-color: #F8FAFC;"><MudText Typo="Typo.body2" Style="font-weight: 800; color: #1E293B;">@item.SaldoPrevisto.ToString("C2")</MudText></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <div class="d-flex align-center justify-center" style="height: 150px; border: 2px dashed #E2E8F0; border-radius: 12px;">
                        <MudText Style="color: #94A3B8;">Ative a recorrência em seus lançamentos para ver a projeção detalhada.</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private DashboardDto? dashboard;
    private bool _carregando = true;

    // Configurações Pizza
    private double[] dataGrafico = Array.Empty<double>();
    private string[] labelsGrafico = Array.Empty<string>();
    private ChartOptions _chartOptions = new() { ChartPalette = new[] { "#EF4444", "#F59E0B", "#3B82F6", "#8B5CF6", "#10B981" }, ShowLegend = false };

    // Configurações Linha
    private List<ChartSeries> seriesPrevisao = new();
    private string[] labelsPrevisao = Array.Empty<string>();
    private ChartOptions _lineOptions = new() { ChartPalette = new[] { "#10B981", "#EF4444", "#3B82F6" }, YAxisLines = true, XAxisLines = false, InterpolationOption = InterpolationOption.NaturalSpline };

    public void Dispose() => FinanceState.OnAccountChanged -= HandleAccountChanged;

    protected override async Task OnInitializedAsync()
    {
        PageState.SetTitle("Dashboard");
        FinanceState.OnAccountChanged += HandleAccountChanged;
        await CarregarDadosDashboard();
    }

    private async void HandleAccountChanged()
    {
        await InvokeAsync(async () => { await CarregarDadosDashboard(); StateHasChanged(); });
    }

    public async Task CarregarDadosDashboard()
    {
        try
        {
            _carregando = true;
            if (LocalDb.CacheDashboard != null && LocalDb.CacheDashboard.Any())
            {
                var cache = LocalDb.CacheDashboard.FirstOrDefault();
                if (cache != null) { dashboard = cache; MapearGraficos(); _carregando = false; await InvokeAsync(StateHasChanged); }
            }

            Guid? idParaBuscar = FinanceState.SelectedAccountId;
            if (idParaBuscar == null)
            {
                var contas = await Http.GetFromJsonAsync<List<ContaDto>>("api/contas");
                if (contas != null && contas.Any())
                {
                    var contaPadrao = contas.FirstOrDefault(c => c.Ativo) ?? contas.First();
                    idParaBuscar = contaPadrao.Id;
                    FinanceState.SetAccount(contaPadrao.Id, contaPadrao.Nome);
                }
            }

            if (idParaBuscar != null)
            {
                var dadosApi = await Http.GetFromJsonAsync<DashboardDto>($"api/Dashboard/{idParaBuscar}");
                if (dadosApi != null)
                {
                    dashboard = dadosApi;
                    MapearGraficos();
                    LocalDb.CacheDashboard.Clear();
                    LocalDb.CacheDashboard.Add(dashboard);
                    await LocalDb.SaveChanges();
                }
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { _carregando = false; await InvokeAsync(StateHasChanged); }
    }

    private void MapearGraficos()
    {
        if (dashboard == null) return;

        // Donut
        dataGrafico = dashboard.DespesasPorCategoria.Select(x => (double)x.Valor).ToArray();
        labelsGrafico = dashboard.DespesasPorCategoria.Select(x => x.Categoria).ToArray();

        // Previsão
        if (dashboard.PrevisaoProximosMeses != null)
        {
            var culturaPt = new CultureInfo("pt-BR");

            // Tradução e formatação robusta dos meses
            foreach (var item in dashboard.PrevisaoProximosMeses)
            {
                // Se o backend enviar "APR" ou "APR.", tentamos converter.
                // Usamos uma lista de formatos conhecidos para garantir.
                string[] formats = { "MMM", "MMM.", "MMMM" };
                if (DateTime.TryParseExact(item.Mes.TrimEnd('.'), formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt))
                {
                    item.Mes = dt.ToString("MMM", culturaPt).ToUpper().Replace(".", "");
                }
            }

            labelsPrevisao = dashboard.PrevisaoProximosMeses.Select(x => x.Mes).ToArray();
            seriesPrevisao = new List<ChartSeries>
            {
                new ChartSeries { Name = "Receitas", Data = dashboard.PrevisaoProximosMeses.Select(x => (double)x.Receitas).ToArray() },
                new ChartSeries { Name = "Despesas", Data = dashboard.PrevisaoProximosMeses.Select(x => (double)x.Despesas).ToArray() },
                new ChartSeries { Name = "Saldo Projetado", Data = dashboard.PrevisaoProximosMeses.Select(x => (double)x.SaldoPrevisto).ToArray() }
            };
        }
    }
}