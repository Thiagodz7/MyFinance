@page "/contas"
@using MyFinance.Web.DTOs
@using MyFinance.Web.Services
@using MyFinance.Web.Shared
@inject HttpClient Http
@inject IDialogService DialogService
@inject MyFinance.Web.Services.PageStateService PageState
@inject ISnackbar Snackbar
@inject FinanceStateService FinanceState

<PageTitle>Contas - Pejota.io</PageTitle>

@* --- CABEÇALHO PADRONIZADO (Resolve o FAB no Mobile automaticamente) --- *@
<PageHeader Title="Minhas Contas"
            Subtitle="Gerencie seus saldos e bancos"
            ActionText="Nova Conta"
            OnActionClick="@(() => AbrirDialog())">
    <FiltrosExtras>
        <MudCheckBox T="bool"
                     Value="@_mostrarInativos"
                     ValueChanged="@((bool v) => AlternarFiltro(v))"
                     Label="Mostrar Inativos"
                     Color="Color.Primary"
                     Dense="true" />
    </FiltrosExtras>
</PageHeader>

@if (_contas == null)
{
    <div class="d-flex flex-column align-center justify-center mt-15">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Class="mt-4" Style="color: #64748B;">Sincronizando contas...</MudText>
    </div>
}
else if (!_contasFiltered.Any())
{
    @* --- EMPTY STATE PADRÃO TEC AND TEC --- *@
    <MudEmptyState Title="Nenhuma conta"
                   Message="Você ainda não cadastrou nenhuma conta ou o filtro está escondendo tudo."
                   Icon="@Icons.Material.Filled.AccountBalance"
                   IconColor="Color.Info"
                   ActionText="Cadastrar Primeira Conta"
                   OnActionClick="@(() => AbrirDialog())" />
}
else
{
    <MudGrid>
        @foreach (var conta in _contasFiltered)
        {
            <MudItem xs="12" sm="6" md="4">
                @* CARD REFINADO: Bordas suaves e cores do seu tema *@
                <MudPaper Elevation="0"
                          Class="pa-5 d-flex flex-column gap-2 border border-solid"
                          Style="@GetCardStyle(conta)">

                    <div class="d-flex justify-space-between align-start">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #1E293B;">
                                @conta.Nome
                                @if (!conta.Ativo)
                                {
                                    <span style="font-size: 0.7rem; color: #94A3B8; margin-left: 4px;">(INATIVA)</span>
                                }
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: #64748B; text-transform: uppercase; letter-spacing: 1px;">
                                @conta.Banco
                            </MudText>
                        </div>

                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => AbrirDialog(conta))">Editar</MudMenuItem>
                            <MudMenuItem Icon="@(conta.Ativo? Icons.Material.Filled.PowerSettingsNew : Icons.Material.Filled.Refresh)"
                                         IconColor="@(conta.Ativo ? Color.Error : Color.Success)"
                                         OnClick="@(() => AlternarStatusConta(conta))">
                                @(conta.Ativo ? "Inativar" : "Reativar")
                            </MudMenuItem>
                        </MudMenu>
                    </div>

                    <div class="mt-4">
                        <MudText Typo="Typo.caption" Style="color: #94A3B8; font-weight: 600;">SALDO ATUAL</MudText>
                        <MudText Typo="Typo.h5"
                                 Style="@($"font-weight: 800; color: {(conta.Ativo ? (conta.SaldoAtual >= 0 ? "#10B981" : "#EF4444") : "#94A3B8")};")">
                            @conta.SaldoAtual.ToString("C2")
                        </MudText>
                    </div>

                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<ContaDto>? _contas;
    private IEnumerable<ContaDto> _contasFiltered => _mostrarInativos ? _contas : _contas?.Where(c => c.Ativo);
    private bool _mostrarInativos = false;

    // Helper para manter o HTML limpo e gerenciar o visual do card
    private string GetCardStyle(ContaDto conta)
    {
        var borderColor = conta.Ativo ? "#10B981" : "#CBD5E1";
        var bgColor = conta.Ativo ? "#FFFFFF" : "#F8FAFC";
        var opacity = conta.Ativo ? "1" : "0.7";

        return $"border-radius: 16px; border-left: 6px solid {borderColor} !important; background-color: {bgColor}; opacity: {opacity}; border-top: 1px solid #E2E8F0; border-right: 1px solid #E2E8F0; border-bottom: 1px solid #E2E8F0;";
    }

    protected override async Task OnInitializedAsync()
    {
        PageState.SetTitle("Contas Bancárias");
        await CarregarContas();
    }

    private async Task CarregarContas()
    {
        try { _contas = await Http.GetFromJsonAsync<List<ContaDto>>("api/contas"); }
        catch (Exception ex) { Snackbar.Add($"Erro: {ex.Message}", Severity.Error); }
    }

    private void AlternarFiltro(bool mostrar) => _mostrarInativos = mostrar;

    private async Task AbrirDialog(ContaDto? conta = null)
    {
        var parameters = new DialogParameters { { "ContaEditar", conta } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ContaDialog>(conta == null ? "Nova Conta" : "Editar Conta", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled) await CarregarContas();
    }

    private async Task AlternarStatusConta(ContaDto conta)
    {
        string acao = conta.Ativo ? "inativar" : "reativar";
        bool? result = await DialogService.ShowMessageBox("Confirmação", $"Deseja {acao} a conta '{conta.Nome}'?", "Sim", "Cancelar");
        if (result != true) return;

        try
        {
            var response = await Http.PatchAsJsonAsync($"api/contas/{conta.Id}/status", new { Ativo = !conta.Ativo });
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Conta {acao}da!", Severity.Success);
                await CarregarContas();
                if (conta.Id == FinanceState.SelectedAccountId && !conta.Ativo)
                    FinanceState.SetAccount(null, "Todas as Contas");

                PageState.NotifyCreateNewContaChanged();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Erro: {ex.Message}", Severity.Error); }
    }
}