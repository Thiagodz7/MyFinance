@using MyFinance.Web.DTOs
@using MyFinance.Web.Services
@inject HttpClient Http
@inject FinanceStateService FinanceState
@inject PageStateService PageState
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true" FullWidth="false">
    <ActivatorContent>
        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   Class="seletor-conta-btn"
                   StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                   EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                   Style="text-transform: none; font-weight: 500; width: 100%; justify-content: flex-start; padding-left: 16px;">
            @(FinanceState.SelectedAccountName ?? "Todas as Contas")
        </MudButton>
    </ActivatorContent>
    <ChildContent>
        <MudMenuItem OnClick="@(() => OnAccountSelected(null))">
            <MudText Typo="Typo.body2">Todas as Contas</MudText>
        </MudMenuItem>

        @if (_contas != null)
        {
            @foreach (var conta in _contas)
            {
                <MudMenuItem OnClick="@(() => OnAccountSelected(conta.Id))">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                 Size="Size.Small"
                                 Class="mr-2"
                                 Color="@(FinanceState.SelectedAccountId == conta.Id ? Color.Success : Color.Transparent)" />
                        <MudText Typo="Typo.body2">@conta.Nome</MudText>
                    </div>
                </MudMenuItem>
            }
        }
    </ChildContent>
</MudMenu>

@code {
    private List<ContaDto>? _contas;

    protected override async Task OnInitializedAsync()
    {
        await CarregarContas();
        PageState.OnCreateNewContaChanged += HandleContasChanged;
    }

    private async void HandleContasChanged()
    {
        await InvokeAsync(async () =>
        {
            await CarregarContas();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        PageState.OnCreateNewContaChanged -= HandleContasChanged;
    }

    private async Task CarregarContas()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity == null || !user.Identity.IsAuthenticated) return;

            var todasContas = await Http.GetFromJsonAsync<List<ContaDto>>("api/contas");

            if (todasContas != null)
            {
                _contas = todasContas.Where(c => c.Ativo).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar contas: {ex.Message}");
        }
    }

    private void OnAccountSelected(Guid? id)
    {
        var nome = _contas?.FirstOrDefault(c => c.Id == id)?.Nome ?? "Todas as Contas";
        FinanceState.SetAccount(id, nome);
        // O StateHasChanged aqui garante que o texto do botão mude na hora
        StateHasChanged();
    }
}