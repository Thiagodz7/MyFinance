@page "/login"
@using MyFinance.Web.DTOs.Auth
@using MyFinance.Web.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@layout MyFinance.Web.Layout.LoginLayout
@attribute [AllowAnonymous]

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full" Style="height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8" Width="100%" MaxWidth="400px">

        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h5">MyFinance Login</MudText>
        </MudStack>

        <MudForm @ref="form" @bind-IsValid="@success">
            <MudTextField T="string" Label="Email" Variant="Variant.Outlined"
                          @bind-Value="loginModel.Email" Required="true" RequiredError="Email é obrigatório"
                          InputType="InputType.Email" Class="mt-4" />

            <MudTextField T="string" Label="Senha" Variant="Variant.Outlined"
                          @bind-Value="loginModel.Password" Required="true" RequiredError="Senha é obrigatória"
                          InputType="InputType.Password" Class="mt-4" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                       Class="mt-6" OnClick="FazerLogin" Disabled="@(_processando)">
                @if (_processando)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Entrando...</MudText>
                }
                else
                {
                    <MudText>Entrar</MudText>
                }
            </MudButton>
        </MudForm>

        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4">
            Não tem conta? <MudLink Href="/registro">Cadastre-se</MudLink>
        </MudText>

    </MudPaper>
</MudContainer>

@code {
    private LoginUserDto loginModel = new LoginUserDto();
    bool success;
    MudForm form;
    bool _processando = false;

    private async Task FazerLogin()
    {
        await form.Validate();
        if (!form.IsValid) return;

        _processando = true;
        var resultado = await AuthService.Login(loginModel);
        _processando = false;

        if (resultado)
        {
            Snackbar.Add("Login realizado com sucesso!", Severity.Success);
            Navigation.NavigateTo("/"); // Vai para a Home
        }
        else
        {
            Snackbar.Add("Email ou senha inválidos.", Severity.Error);
        }
    }
}