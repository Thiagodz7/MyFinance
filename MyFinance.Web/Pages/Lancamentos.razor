@page "/lancamentos"
@using MyFinance.Web.DTOs
@using MyFinance.Web.Services
@using MyFinance.Web.Shared
@inject HttpClient Http
@inject IDialogService DialogService
@inject MyFinance.Web.Services.PageStateService PageState
@inject ISnackbar Snackbar

<style>
    /* CSS Isolatado para a modal de exclusão */
    .modal-exclusao-pejota .mud-dialog-actions .mud-button-text-primary {
        color: #fb8c00 !important;
        font-weight: 800 !important;
    }

        .modal-exclusao-pejota .mud-dialog-actions .mud-button-text-primary:hover {
            background-color: #fb8c00 !important;
            color: white !important;
        }

    .modal-exclusao-pejota .mud-dialog-actions .mud-button-text-secondary {
        color: #f44336 !important;
        font-weight: 800 !important;
    }

        .modal-exclusao-pejota .mud-dialog-actions .mud-button-text-secondary:hover {
            background-color: #f44336 !important;
            color: white !important;
        }

    .modal-exclusao-pejota .mud-dialog-actions .mud-button-text-default:hover {
        background-color: #9e9e9e !important;
        color: white !important;
    }

    .op-box {
        padding: 12px;
        border-radius: 8px;
        margin-top: 8px;
        font-size: 0.9rem;
        border-left: 4px solid;
    }
</style>

<PageTitle>Lançamentos - Pejota.io</PageTitle>

@implements IDisposable
@inject FinanceStateService FinanceState

<MudText Typo="Typo.h4" Class="mb-4">Extrato</MudText>

@if (_carregando)
{
    <div class="d-flex flex-column align-center justify-center mt-15">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Class="mt-4" Style="color: #64748B;">Sincronizando extrato...</MudText>
    </div>
}
else if (extrato == null || (extrato.Lancamentos != null && !extrato.Lancamentos.Any()))
{
    @* --- NOSSO NOVO EMPTY STATE ESTILO TEC AND TEC --- *@
    <MudEmptyState Title="Extrato Vazio"
                   Message="Não encontramos nenhum lançamento para esta conta neste período."
                   Icon="@Icons.Material.Filled.ReceiptLong"
                   IconColor="Color.Secondary"
                   ActionText="Novo Lançamento"
                   OnActionClick="@(() => AbrirDialog(null))" />
}
else
{
    @* --- SELETOR DE MÊS/ANO --- *@
    <div class="d-flex align-center gap-4 mb-4" style="max-width: 300px;">
        <MudDatePicker Label="Mês de Referência"
                       @bind-Date="_dataFiltro"
                       OpenTo="OpenTo.Month"
                       FixDay="1"
                       DateFormat="MM/yyyy"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Color="Color.Primary" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="BuscarPorPeriodo"
                   DisableElevation="true">
            Buscar
        </MudButton>
    </div>

    <MudPaper Class="pa-4 mb-6 d-flex flex-wrap justify-space-between align-center gap-4" Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 12px; background-color: #F8FAFC;">

        @* Bloco 1: Nome da Conta *@
        <div style="flex: 1; min-width: 150px;">
            <MudText Typo="Typo.caption" Style="color: #94A3B8; font-weight: 700; text-transform: uppercase;">Conta Selecionada</MudText>
            <MudText Typo="Typo.h6" Style="color: #1E293B; font-weight: 800; line-height: 1.2;">@extrato.NomeConta</MudText>
        </div>

        @* Bloco 2: Saldo Anterior (O que sobrou dos meses passados) *@
        <div class="text-end" style="flex: 1; min-width: 120px; border-right: 1px solid #E2E8F0; padding-right: 16px;">
            <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 700; text-transform: uppercase;">Saldo Anterior</MudText>
            <MudText Typo="Typo.subtitle1" Color="@(extrato.SaldoAnterior >= 0 ? Color.Success : Color.Error)" Style="font-weight: 700;">
                @extrato.SaldoAnterior.ToString("C2")
            </MudText>
        </div>

        @* Bloco 3: Lucro do Mês (Entradas vs Saídas do mês atual) *@
        <div class="text-end" style="flex: 1; min-width: 120px; border-right: 1px solid #E2E8F0; padding-right: 16px;">
            <MudText Typo="Typo.caption" Style="color: #64748B; font-weight: 700; text-transform: uppercase;">Resultado do Mês</MudText>
            <MudText Typo="Typo.subtitle1" Color="@(extrato.LucroDoMes >= 0 ? Color.Success : Color.Error)" Style="font-weight: 700;">
                @(extrato.LucroDoMes > 0 ? "+" : "")@extrato.LucroDoMes.ToString("C2")
            </MudText>
        </div>

        @* Bloco 4: Saldo Atual (O Valor Final na Conta) *@
        <div class="text-end" style="flex: 1; min-width: 120px;">
            <MudText Typo="Typo.caption" Style="color: #0F172A; font-weight: 800; text-transform: uppercase;">Saldo Atual</MudText>
            <MudText Typo="Typo.h5" Color="@(extrato.SaldoAtual >= 0 ? Color.Success : Color.Error)" Style="font-weight: 900;">
                @extrato.SaldoAtual.ToString("C2")
            </MudText>
        </div>
    </MudPaper>

    <div class="d-flex justify-space-between align-center mb-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => AbrirDialog(null))">
            Novo Lançamento
        </MudButton>
    </div>

    <MudTable Items="@extrato.Lancamentos" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Data</MudTh>
            <MudTh>Descrição</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Valor</MudTh>
            <MudTh>Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data">@context.Data.ToString("dd/MM/yyyy")</MudTd>
            <MudTd DataLabel="Descrição">
                <div class="d-flex align-center">
                    @context.Descricao
                    @if (context.EhRecorrente)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="ml-2">
                            @context.ParcelaAtual/@context.TotalParcelas
                        </MudChip>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Categoria">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                    @context.Categoria
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Valor">
                <MudText Color="@(context.Valor >= 0 ? Color.Success : Color.Error)" Style="font-weight: 700;">
                    @context.Valor.ToString("C2")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Ações">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" OnClick="@(() => AbrirDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => ConfirmarExclusaoComOpcoes(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private ExtratoDto? extrato;
    private bool _carregando = true;
    private DateTime? _dataFiltro = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);

    public enum TipoExclusaoRecorrencia
    {
        ApenasEste = 0,
        EsteEProximos = 1,
        TodosDoGrupo = 2
    }

    private async Task ConfirmarExclusaoComOpcoes(LancamentoDto lancamento)
    {
        // Definimos uma classe específica para esta modal não afetar a de "Editar"
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackgroundClass = "modal-exclusao-pejota" // Isso isola o CSS
        };

        if (lancamento.EhRecorrente)
        {
            var msn = $@"
            <div style='display: flex; flex-direction: column; gap: 12px;'>
                <p>Este item faz parte de uma <b>recorrência</b>.</p>
                <div class='op-box' style='background-color: #FFF4E5; border-color: #fb8c00; color: #663C00;'>
                    <b>OPÇÃO 1:</b> Apaga apenas a parcela de <b>{lancamento.Data:dd/MM/yyyy}</b>.
                </div>
                <div class='op-box' style='background-color: #FFEBEE; border-color: #f44336; color: #B71C1C;'>
                    <b>OPÇÃO 2:</b> Apaga esta e <b>TODAS AS FUTURAS</b>.
                </div>
            </div>";

            var result = await DialogService.ShowMessageBox(
                "Segurança: Recorrência",
                (MarkupString)msn,
                yesText: "APENAS ESTE",
                noText: "ESTE E PRÓXIMOS",
                cancelText: "CANCELAR",
                options: options
            );

            if (result == true) await ExecutarExclusao(lancamento.Id, TipoExclusaoRecorrencia.ApenasEste);
            else if (result == false) await ExecutarExclusao(lancamento.Id, TipoExclusaoRecorrencia.EsteEProximos);
        }
        else
        {
            var result = await DialogService.ShowMessageBox(
                "Confirmar Exclusão",
                (MarkupString)$"Deseja apagar <b>'{lancamento.Descricao}'</b>?",
                yesText: "EXCLUIR",
                cancelText: "CANCELAR",
                options: options
            );
            if (result == true) await ExecutarExclusao(lancamento.Id, TipoExclusaoRecorrencia.ApenasEste);
        }
    }

    private async Task ExecutarExclusao(Guid id, TipoExclusaoRecorrencia tipoExclusao)
    {
        try
        {
            var valor = (int)tipoExclusao;
            // O nome do parâmetro na URL deve ser EXATAMENTE 'tipoExclusao' (igual ao nome no argumento do Controller)
            var url = $"api/Lancamentos/{id}?tipoExclusao={valor}";

            Console.WriteLine($"Chamando URL: {url}"); 

            var response = await Http.DeleteAsync(url);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Excluído com sucesso!", Severity.Success);
                FinanceState.SetAccount(FinanceState.SelectedAccountId, FinanceState.SelectedAccountName);
                await CarregarExtrato();
                StateHasChanged();
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Erro ao excluir: {erro}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro crítico: {ex.Message}", Severity.Error);
        }
    }

    private async Task AbrirDialog(LancamentoDto? lancamentoParaEditar = null)
    {
        if (extrato == null) return;

        var parameters = new DialogParameters();
        parameters.Add("ContaId", extrato.ContaId);
        parameters.Add("LancamentoEditar", lancamentoParaEditar);

        var title = lancamentoParaEditar == null ? "Novo Lançamento" : "Editar Lançamento";
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = await DialogService.ShowAsync<LancamentoDialog>(title, parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            await CarregarExtrato();
            FinanceState.SetAccount(FinanceState.SelectedAccountId, FinanceState.SelectedAccountName);
        }
    }

    private async Task CarregarExtrato()
    {
        try
        {
            _carregando = true;
            var idContaSelecionada = FinanceState.SelectedAccountId;

            // Pega o mês/ano do picker ou cai no default
            var mes = _dataFiltro?.Month ?? DateTime.Now.Month;
            var ano = _dataFiltro?.Year ?? DateTime.Now.Year;

            if (idContaSelecionada != null && idContaSelecionada != Guid.Empty)
            {
                extrato = await Http.GetFromJsonAsync<ExtratoDto>($"api/Contas/{idContaSelecionada}/extrato?mes={mes}&ano={ano}");
            }
            else
            {
                var contas = await Http.GetFromJsonAsync<List<ContaDto>>("api/contas");

                if ((contas != null && contas.Any()))
                {
                    var contaAtiva = contas.FirstOrDefault(c => c.Ativo) ?? contas.First();
                    extrato = await Http.GetFromJsonAsync<ExtratoDto>($"api/Contas/{contaAtiva.Id}/extrato?mes={mes}&ano={ano}");
                    FinanceState.SetAccount(contaAtiva.Id, contaAtiva.Nome);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task BuscarPorPeriodo()
    {
        await CarregarExtrato();
        StateHasChanged();
    }

    public void Dispose()
    {
        FinanceState.OnAccountChanged -= HandleAccountChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        PageState.SetTitle("Lançamentos");
        FinanceState.OnAccountChanged += HandleAccountChanged;
        await CarregarExtrato();
    }

    private async void HandleAccountChanged()
    {
        await InvokeAsync(async () =>
        {
            await CarregarExtrato();
            StateHasChanged();
        });
    }
}