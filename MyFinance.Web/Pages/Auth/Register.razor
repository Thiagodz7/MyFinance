@page "/registro"
@layout MyFinance.Web.Layout.LoginLayout
@attribute [AllowAnonymous]

@using MyFinance.Web.DTOs.Auth
@using MyFinance.Web.Services.Auth
@using System.Text.RegularExpressions
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Criar Conta - Pejota.io</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full" Style="height: 100vh;">
    <MudPaper Elevation="3" Class="pa-8" Width="100%" MaxWidth="400px" Style="border-radius: 16px;">

        <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mb-8">
            <MudImage Src="icon-192.png" Alt="Pejota.io Logo" Width="64" Height="64" Class="mb-2 rounded-lg" />
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1E293B;">
                Comece no Pejota<span style="color: #3B82F6;">.io</span>
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #64748B;" Align="Align.Center">
                A gestão financeira inteligente para o profissional PJ e Pessoa Física.
            </MudText>
        </MudStack>

        <MudForm @ref="form" @bind-IsValid="@success">

            <MudTextField T="string" Label="Email" Variant="Variant.Outlined"
                          @bind-Value="registerModel.Email"
                          Required="true"
                          RequiredError="O email é obrigatório."
                          Validation="@(new Func<string, IEnumerable<string>>(ValidateEmail))"
                          InputType="InputType.Email"
                          Class="mb-4" />

            <MudTextField T="string" Label="Crie uma Senha" Variant="Variant.Outlined"
                          @bind-Value="registerModel.Password"
                          Required="true"
                          RequiredError="A senha é obrigatória."
                          InputType="@PasswordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@PasswordInputIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          HelperText="Mín. 6 caracteres, maiúscula e símbolo"
                          Class="mb-4" />

            <MudTextField T="string" Label="Confirme a Senha" Variant="Variant.Outlined"
                          @bind-Value="registerModel.ConfirmPassword"
                          Required="true"
                          InputType="InputType.Password"
                          Validation="@(new Func<string, string>(PasswordMatch))"
                          Class="mb-6" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                       Style="border-radius: 8px; font-weight: 600; letter-spacing: 0.5px;"
                       OnClick="FazerRegistro" Disabled="@(_processando)">
                @if (_processando)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" Color="Color.Surface" />
                    <MudText Class="ms-2">Criando conta...</MudText>
                }
                else
                {
                    <MudText>Registrar</MudText>
                }
            </MudButton>
        </MudForm>

        <MudDivider Class="my-6" />

        <MudText Typo="Typo.body2" Align="Align.Center">
            Já possui cadastro?
            <MudLink Href="/login" Color="Color.Primary" Style="font-weight: 600;" Underline="Underline.Hover">Faça Login</MudLink>
        </MudText>

    </MudPaper>
</MudContainer>

@code {
    private RegisterUserDto registerModel = new RegisterUserDto();
    bool success;
    MudForm form;
    bool _processando = false;

    // Controle de visibilidade da senha
    bool _isShow;
    InputType PasswordInput = InputType.Password;
    string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePasswordVisibility()
    {
        if (_isShow)
        {
            _isShow = false;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
        else
        {
            _isShow = true;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
    }

    private string PasswordMatch(string confirmPassword)
    {
        if (registerModel.Password != confirmPassword)
            return "As senhas não conferem";
        return null;
    }

    private IEnumerable<string> ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            yield return "O email é obrigatório";
            yield break;
        }

        if (!Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            yield return "Formato de email inválido";
    }

    private async Task FazerRegistro()
    {
        await form.Validate();
        if (!form.IsValid) return;

        _processando = true;
        var resultado = await AuthService.Register(registerModel);
        _processando = false;

        if (resultado)
        {
            Snackbar.Add("Conta criada com sucesso! Bem-vindo.", Severity.Success);
            Navigation.NavigateTo("/");
        }
        else
        {
            Snackbar.Add("Erro ao criar conta. Verifique os dados ou tente outro email.", Severity.Error);
        }
    }
}