@inherits LayoutComponentBase
@using MyFinance.Web.Pages.Conta.Componentes
@using MyFinance.Web.Themes
@inject MyFinance.Web.Services.PageStateService PageState
@inject MyFinance.Web.Services.FinanceStateService FinanceState

@implements IAsyncDisposable
@inject IBrowserViewportService ViewportService
@implements IBrowserViewportObserver

@using MyFinance.Web.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider Theme="MyFinanceTheme.DefaultTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="@(_isMobile ? DrawerClipMode.Always : DrawerClipMode.Never)"
               Elevation="0"
               Variant="@(_isMobile ? DrawerVariant.Temporary : DrawerVariant.Mini)"
               Fixed="true">

        <MudDrawerHeader Class="@(_drawerOpen ? "d-flex align-center justify-start pa-4" : "d-flex align-center justify-center pa-2")">
            @* <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Secondary" Size="Size.Large" Class="@(_drawerOpen ? "mr-2" : "")" /> *@
            <MudImage Src="icon-192.png" Alt="Pejota.io Logo" Width="32" Height="32" Class="mr-3 rounded-lg" />

            @if (_drawerOpen)
            {
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: white;">Pejota.io</MudText>
            }
        </MudDrawerHeader>

        <MudNavMenu Class="mt-4" Color="Color.Secondary">

            @* Se for Desktop, mostra tudo na lateral. Se for Mobile, os principais vão para a barra inferior *@
            @if (!_isMobile)
            {
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                <MudNavLink Href="/lancamentos" Icon="@Icons.Material.Filled.List">Lançamentos</MudNavLink>
                <MudNavLink Href="/contas" Icon="@Icons.Material.Filled.AccountBalance">Contas</MudNavLink>
                <MudNavLink Href="/relatorios"
                            Icon="@Icons.Material.Filled.PieChart"
                            Style="color: rgba(255,255,255, 0.4); cursor: not-allowed;"
                            @onclick:preventDefault="true">
                    Relatórios (Em breve)
                </MudNavLink>
            }

            @if (_drawerOpen)
            {
                <MudText Typo="Typo.subtitle2" Class="px-4 mt-6 mb-2" Style="color: #64748B;">CONFIGURAÇÕES</MudText>
            }

            <MudNavLink Href="/categorias" Icon="@Icons.Material.Filled.Category">Categorias</MudNavLink>

            @* Botão de Sair no menu lateral para Mobile *@
            @if (_isMobile)
            {
                <MudNavLink OnClick="Sair" Icon="@Icons.Material.Filled.Logout" Style="color: #EF4444;">Sair</MudNavLink>
            }
        </MudNavMenu>

        <div class="d-flex justify-center mt-auto mb-4">
            <MudText Typo="Typo.caption" Style="color: #64748B;">
                @(_drawerOpen ? "v1.0.0" : "v1.0")
            </MudText>
        </div>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <div class="px-4 pb-4 pt-2">
                <MudText Typo="Typo.overline" Style="color: #94A3B8; display: block; margin-bottom: 4px;">CONTA ATIVA</MudText>

                <SeletorConta></SeletorConta>
            </div>
            <MudDivider />
        </MudHidden>

    </MudDrawer>


    <MudAppBar Elevation="1" Dense="false" Fixed="true" Color="Color.Surface" Class="px-4">
        <MudIconButton Icon="@(_drawerOpen? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />

        <MudText Typo="Typo.h6" Class="ml-3 fw-bold" Style="color: #1E293B;">
            @PageState.Title
        </MudText>

        <MudSpacer />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="mr-4">
                <SeletorConta></SeletorConta>
            </div>
        </MudHidden>

        @if (!_isMobile)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Default" OnClick="Sair" />
        }
    </MudAppBar>

    @* Adicionamos a classe mobile-content-padding aqui *@
    <MudMainContent Class="@($"px-4 {(_isMobile ? "mobile-content-padding" : "")}")" Style="padding-top: 85px;">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>

    @* --- BOTTOM NAVIGATION EXCLUSIVA PARA MOBILE --- *@
    @if (_isMobile)
    {
        <div class="bottom-nav-bar">
            <NavLink href="/" class="bottom-nav-item" Match="NavLinkMatch.All" ActiveClass="active">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Medium" />
                <span>Início</span>
            </NavLink>

            <NavLink href="/lancamentos" class="bottom-nav-item" ActiveClass="active">
                <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Medium" />
                <span>Extrato</span>
            </NavLink>

            <NavLink href="/contas" class="bottom-nav-item" ActiveClass="active">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Medium" />
                <span>Contas</span>
            </NavLink>
        </div>
    }
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isMobile;
    public Guid Id { get; } = Guid.NewGuid();

    protected override void OnInitialized()
    {
        PageState.OnTitleChanged += HandleTitleChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ViewportService.SubscribeAsync(this, fireImmediately: true);
        }
    }

    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs e)
    {
        bool wasMobile = _isMobile;
        _isMobile = e.Breakpoint <= Breakpoint.Sm;

        await InvokeAsync(() =>
        {
            // Força o menu a fechar quando muda para mobile, e abrir quando vai para PC
            if (_isMobile != wasMobile)
            {
                _drawerOpen = !_isMobile;
            }
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync() => await ViewportService.UnsubscribeAsync(this);

    private void HandleTitleChanged() => StateHasChanged();

    public void Dispose()
    {
        PageState.OnTitleChanged -= HandleTitleChanged;
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Sair()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}